# =============================
# Environment Configuration Template
# =============================
# Copy this file to .env and update values for your environment
# NEVER commit .env file to git - it contains sensitive credentials

# =============================
# Application Configuration
# =============================

# Application environment
# Values: development, staging, production
NODE_ENV=development

# Server port
PORT=3000

# Log level for application
# Values: debug, log, warn, error, verbose
LOG_LEVEL=debug

# =============================
# JWT Authentication Configuration
# =============================

# JWT secret key for token signing and verification
# IMPORTANT: Use a strong random string (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# JWT token expiration time in seconds
# Default: 3600 (1 hour)
# Can use: 3600 (1h), 86400 (24h), 604800 (7d)
JWT_EXPIRATION_TIME=3600

# =============================
# Database Configuration
# =============================

# Database type
# Currently supports: mysql
DB_TYPE=mysql

# Database host
# Development: localhost or 127.0.0.1
# Production: Use RDS endpoint, managed database host, or private IP
DB_HOST=localhost

# Database port
# MySQL default: 3306
DB_PORT=3306

# Database username
# Development: root
# Production: Use specific non-root user with limited permissions
DB_USERNAME=root

# Database password
# Keep secure and different for each environment
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
DB_PASSWORD=root

# Database name
# Development: metro_rail_db_dev
# Production: metro_rail_db_prod
DB_NAME=metro_rail_db_dev

# Enable query logging in development
# Set to 'true' only in development for debugging
DB_LOGGING=false

# Automatically synchronize database schema with entities
# IMPORTANT: Set to 'false' in production - use migrations instead
DB_SYNCHRONIZE=true

# Maximum database connection pool size
# Recommended: 5-20 depending on load
DB_POOL_SIZE=10

# =============================
# Email Configuration (Optional)
# =============================

# Email service provider for OTP/notifications
# Supported: sendgrid, mailgun, smtp
EMAIL_SERVICE=smtp

# SMTP Configuration (if using SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@metrorailapp.com

# SendGrid Configuration (alternative)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Mailgun Configuration (alternative)
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-domain.mailgun.org

# =============================
# OTP Configuration
# =============================

# OTP expiration time in minutes
OTP_EXPIRATION_MINUTES=15

# OTP length in digits
# Recommended: 6 digits
OTP_LENGTH=6

# =============================
# CORS Configuration
# =============================

# Allowed origins for CORS requests
# Comma-separated list
# Development: http://localhost:3001,http://localhost:3000
# Production: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================
# Rate Limiting Configuration
# =============================

# Rate limit window in seconds
RATE_LIMIT_WINDOW=60

# Maximum requests per window
RATE_LIMIT_MAX=100

# =============================
# File Upload Configuration
# =============================

# Maximum file upload size in bytes (10MB)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf

# Upload directory
UPLOAD_DIR=./uploads

# =============================
# Monitoring & Analytics
# =============================

# Sentry DSN for error tracking
# Get from: https://sentry.io/
# Leave empty to disable
SENTRY_DSN=

# Google Analytics Tracking ID (optional)
GOOGLE_ANALYTICS_ID=

# =============================
# Third-Party Services
# =============================

# AWS Configuration (optional)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Twilio Configuration (for SMS - optional)
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+1234567890

# =============================
# Feature Flags
# =============================

# Enable/disable features
ENABLE_REGISTRATION=true
ENABLE_2FA=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=false

# =============================
# Security Configuration
# =============================

# HTTPS enforcement
# development: false, production: true
ENFORCE_HTTPS=false

# CORS enabled
ENABLE_CORS=true

# API key for internal services (if used)
INTERNAL_API_KEY=

# =============================
# Development Only
# =============================

# Database seed on startup (development only)
SEED_DATABASE=false

# Mock data generation
USE_MOCK_DATA=false

# Debug mode
DEBUG_MODE=false

# =============================
# Additional Configuration
# =============================

# Application name
APP_NAME=Metro Rail App

# Application version
APP_VERSION=0.0.1

# Application timezone
TZ=UTC

# Custom configuration as needed
# Add more environment variables as your application grows
